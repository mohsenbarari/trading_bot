  showAttachmentMenu.value = !showAttachmentMenu.value
}

onUnmounted(() => {
  messagesContainerResizeObserver?.disconnect()
  messagesContainerResizeObserver = null
  window.removeEventListener('resize', updateIsMobile)
  stopPolling()
  stopStatusPolling()
  clearBackStack()
})

