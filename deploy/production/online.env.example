# Production deployment manifest for the "Iran online" scenario.
# Copy this file outside git tracking, fill it, then pass it to:
#   scripts/production_deploy_online.sh --manifest /path/to/online.env <command>

# --- Local / foreign control plane ---
LOCAL_PROJECT_DIR=/root/trading-bot/trading_bot
LOCAL_FRONTEND_DIR=/root/trading-bot/trading_bot/frontend
LOCAL_DIST_DIR=/root/trading-bot/trading_bot/mini_app_dist
FOREIGN_PUBLIC_IP=65.109.216.187
FOREIGN_PUBLIC_DOMAIN=coin.362514.ir
FOREIGN_SERVER_URL=https://coin.362514.ir
FOREIGN_SERVER_DOMAIN=coin.362514.ir
FOREIGN_SERVER_ALIASES=coin.362514.ir
FOREIGN_TIMEZONE=UTC

# --- Iran SSH access ---
IRAN_HOST=65.109.220.59
IRAN_SSH_USER=root
IRAN_SSH_PORT=37067
IRAN_SSH_AUTH_METHOD=key
# Leave empty when the foreign server already has the correct key loaded via ssh-agent
# or when the default root SSH keys are already configured for access.
IRAN_SSH_PRIVATE_KEY_PATH=
# IRAN_SSH_PASSWORD=use-only-if-password-auth-is-required
IRAN_PROJECT_DIR=/srv/trading-bot/current
IRAN_DEPLOY_BASE_DIR=/srv/trading-bot
IRAN_TIMEZONE=UTC

# --- Iran public app ---
IRAN_PUBLIC_IP=65.109.220.59
IRAN_APP_DOMAIN=coin.gold-trade.ir
IRAN_PUBLIC_DOMAIN=coin.gold-trade.ir
IRAN_SERVER_URL=https://coin.gold-trade.ir
IRAN_SERVER_DOMAIN=coin.gold-trade.ir
IRAN_SERVER_ALIASES=coin.gold-trade.ir
IRAN_CERTBOT_EMAIL=ops@example.ir

# --- Local / remote env files ---
# Keep the production secret source outside the git working tree. The release
# script renders/copies the final foreign runtime env into LOCAL_PROJECT_DIR/.env.
LOCAL_ENV_SOURCE_PATH=/root/secure-envs/trading-bot/.env.foreign.production
IRAN_ENV_SOURCE_PATH=/root/secure-envs/trading-bot/.env.iran.production
FOREIGN_FRONTEND_URL=https://coin.362514.ir
IRAN_FRONTEND_URL=https://coin.gold-trade.ir
PUBLIC_WEBAPP_URL=https://coin.gold-trade.ir
# Production must fail before deploy if Web Push is disabled or VAPID values are missing.
REQUIRE_WEB_PUSH=1
ENV_BACKUP_DIR=/root/secure-envs/trading-bot/backups
# Emergency-only escape hatch. Keep 0 so LOCAL_ENV_SOURCE_PATH cannot point at repo .env.
ALLOW_PROJECT_ENV_SOURCE=0

# --- Optional runtime toggles ---
IRAN_SKIP_CERTBOT=0
IRAN_SKIP_FRONTEND_BUILD=0
IRAN_DEPLOY_WITH_WAIT=1
IRAN_RUN_POST_DEPLOY_HEALTHCHECK=1
IRAN_ENABLE_UFW=0
IRAN_CONNECTIVITY_MODE=ask
IRAN_SKIP_FOREIGN_DEPLOY=0
# Set to 1 only when frontend/build images/wheelhouse/bootstrap should refresh even if signatures match.
IRAN_FORCE_RELEASE_REFRESH=0
# Dual-platform registration remains disabled until the explicit production gate.
TELEGRAM_DIRECT_REGISTRATION_ENABLED=0
TELEGRAM_REGISTRATION_RECONCILIATION_ENABLED=0
TELEGRAM_LOGIN_OTP_ENABLED=0
OTP_SMS_AUTO_FALLBACK_ENABLED=0
# Required on Iran before TELEGRAM_LOGIN_OTP_ENABLED=1; use a dedicated 32+ character secret.
IRAN_OTP_DELIVERY_STATE_SECRET=
INVITATION_CONTRACT_V2_ENABLED=0
REGISTRATION_SYNC_V2_ENABLED=0
REGISTRATION_SYNC_ACCEPT_UNVERSIONED=1
INVITATION_SMS_STANDARD_ENABLED=0
INVITATION_SMS_CUSTOMER_TIER1_ENABLED=0
INVITATION_SMS_ACCOUNTANT_ENABLED=1
INVITATION_SMS_CUSTOMER_TIER2_ENABLED=1
# Keep 0 for production. Set to 1 only for an intentional emergency deploy from local uncommitted files.
IRAN_ALLOW_DIRTY_RELEASE=0
# Production release must normally run from main and match origin/main exactly.
# These overrides are emergency-only and should be documented in the release log when used.
PRODUCTION_RELEASE_BRANCH=main
IRAN_ALLOW_NON_MAIN_RELEASE=0
IRAN_ALLOW_RELEASE_BRANCH_DRIFT=0
IRAN_SHARED_DATA_MODE=auto
IRAN_SHARED_SEED_BATCH_SIZE=50
# Required only when IRAN_SHARED_DATA_MODE=reset is used non-interactively.
# The exact value must be RESET_IRAN_SHARED_DATA.
IRAN_SHARED_RESET_CONFIRM=
# Sync HTTP clients verify TLS by default. For private/self-signed internal
# certificates, keep verification enabled and set SYNC_CA_BUNDLE to the mounted
# CA bundle path inside the runtime containers. Production gates reject
# SYNC_VERIFY_TLS=0/false unless SYNC_CA_BUNDLE is configured.
SYNC_VERIFY_TLS=true
SYNC_CA_BUNDLE=

# --- SMS.ir ---
# SMSIR_API_KEY and SMSIR_LINE_NUMBER are read from LOCAL_ENV_SOURCE_PATH/IRAN_ENV_SOURCE_PATH
# or requested interactively by scripts/production_deploy_online.sh.
# SMSIR_OTP_TEMPLATE_ID=585147
# SMSIR_OTP_TEMPLATE_PARAMETER=CODE
# SMSIR_INVITATION_TEMPLATE_ID=657938
# SMSIR_INVITATION_TEMPLATE_PARAMETER=NAME
# SMSIR_ACCOUNTANT_INVITATION_TEMPLATE_ID=162103
# SMSIR_CUSTOMER_INVITATION_TEMPLATE_ID=903643

# --- Runtime performance knobs ---
# Foreign normally serves Telegram/global traffic and keeps the current conservative default.
FOREIGN_API_WORKERS=2
# Replacement Iran host baseline: 4 vCPU / 8 GiB RAM. Increase only after a
# production-like benchmark confirms memory, latency, and DB headroom.
IRAN_API_WORKERS=4
# Default per-process SQLAlchemy pool limits. Total possible DB connections are roughly
# (pool + overflow) * API_WORKERS, plus bot/sync-worker usage.
DB_POOL_SIZE=15
DB_MAX_OVERFLOW=10
IRAN_DB_POOL_SIZE=8
IRAN_DB_MAX_OVERFLOW=4
DB_POOL_RECYCLE_SECONDS=3600
DB_POOL_PRE_PING=true
# PostgreSQL container tuning. Foreign keeps PostgreSQL defaults unless its
# compose file is explicitly tuned later. Iran uses the replacement-host
# 8 GiB safety profile; the former high-memory P2 profile must not be reused.
POSTGRES_MAX_CONNECTIONS=500
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=4GB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_RANDOM_PAGE_COST=4
POSTGRES_EFFECTIVE_IO_CONCURRENCY=1
POSTGRES_CHECKPOINT_TIMEOUT=5min
POSTGRES_MAX_WAL_SIZE=1GB
POSTGRES_MIN_WAL_SIZE=80MB
POSTGRES_WAL_BUFFERS=4MB
IRAN_POSTGRES_MAX_CONNECTIONS=150
IRAN_POSTGRES_SHARED_BUFFERS=2GB
IRAN_POSTGRES_EFFECTIVE_CACHE_SIZE=5GB
IRAN_POSTGRES_WORK_MEM=4MB
IRAN_POSTGRES_MAINTENANCE_WORK_MEM=256MB
IRAN_POSTGRES_RANDOM_PAGE_COST=1.2
IRAN_POSTGRES_EFFECTIVE_IO_CONCURRENCY=200
IRAN_POSTGRES_CHECKPOINT_TIMEOUT=15min
IRAN_POSTGRES_MAX_WAL_SIZE=2GB
IRAN_POSTGRES_MIN_WAL_SIZE=512MB
IRAN_POSTGRES_WAL_BUFFERS=16MB
# Redis durability profile. Keep noeviction for sync/realtime queues; leave
# maxmemory unbounded until alerting and safe thresholds are approved.
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction
# Redis-backed leader election keeps singleton API background jobs from running
# once per Uvicorn worker.
BACKGROUND_LEADER_LOCK_TTL_SECONDS=90
BACKGROUND_LEADER_LOCK_REFRESH_SECONDS=30
BACKGROUND_LEADER_RETRY_SECONDS=10

# --- Optional observability receiver hints (do not commit real secrets) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me-before-production
# GRAFANA_ALERT_DEFAULT_RECEIVER=Trading Bot Production Webhook
# GRAFANA_ALERT_CRITICAL_RECEIVER=Trading Bot Production Webhook
# GRAFANA_ALERT_WARNING_RECEIVER=Trading Bot Production Email
# GRAFANA_ALERT_WEBHOOK_URL=https://alerts-bridge.example.internal/trading-bot
# GRAFANA_ALERT_EMAIL_ADDRESSES=ops@example.ir,dev@example.ir
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.example.ir:587
# GF_SMTP_USER=alerts@example.ir
# GF_SMTP_PASSWORD=set-from-secret-store
# GF_SMTP_FROM_ADDRESS=alerts@example.ir
# GF_SMTP_FROM_NAME=Trading Bot Alerts
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,10.10.0.0/24
# OBSERVABILITY_TELEGRAM_USER_HASH_SALT=set-a-dedicated-random-salt
# AUDIT_ANCHOR_HOST_OUTPUT_PATH=/var/lib/trading-bot-observability/audit-anchor.jsonl
# AUDIT_ANCHOR_RELEASE_ID=release-2026-06-10
# AUDIT_ANCHOR_SOURCE_NAME=foreign
# AUDIT_ANCHOR_REMOTE_TARGET=ops@foreign-audit.example:/srv/trading-bot-audit/audit-anchor.jsonl
# AUDIT_ANCHOR_RELAY_OUTPUT_PATH=/srv/trading-bot-audit/staged-anchor.jsonl

# --- Healthcheck ---
IRAN_HEALTHCHECK_URL=https://coin.gold-trade.ir/api/config
IRAN_LOCAL_API_URL=http://127.0.0.1:8000/api/config
