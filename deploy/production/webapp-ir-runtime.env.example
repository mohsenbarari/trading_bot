# Identity-only overlay for the physical Iran standby WebApp.
# Merge these values into that site's secure runtime env; do not use this file
# as a complete application env and do not put real secrets in git.
SERVER_MODE=iran
LOGICAL_AUTHORITY=webapp
PHYSICAL_SITE=webapp_ir
THREE_SITE_DR_ENABLED=true
TOPOLOGY_SCHEMA_VERSION=three-site-dr-v1

# The release process must set these to the deployed commit and Alembic head.
RELEASE_SHA=
ORIGIN_EXPECTED_MIGRATION_REVISION=e653f4a5b7c8
ORIGIN_READINESS_MAX_EVIDENCE_AGE_SECONDS=900
ORIGIN_READINESS_API_KEY=

# Keep disabled until the dedicated witness service is deployed and approved.
WRITER_WITNESS_REQUIRED=false
WRITER_WITNESS_AUTO_RENEW_ENABLED=false
WRITER_WITNESS_PUBLIC_KEY=
WRITER_WITNESS_LEASE_DURATION_SECONDS=180
WRITER_WITNESS_RENEW_INTERVAL_SECONDS=30
WRITER_WITNESS_SAFETY_MARGIN_SECONDS=15
WRITER_WITNESS_MAX_CLOCK_SKEW_SECONDS=5
WRITER_WITNESS_AUTHORITATIVE_SITE=webapp_ir
WRITER_WITNESS_INTERNAL_URL=
WRITER_WITNESS_CLIENT_KEY_ID=
WRITER_WITNESS_CLIENT_SECRET=
WRITER_WITNESS_VERIFY_TLS=true
WRITER_WITNESS_CA_BUNDLE=
WRITER_WITNESS_HTTP_TIMEOUT_SECONDS=3
WRITER_WITNESS_AUTH_MAX_AGE_SECONDS=15

# This value belongs only to the later witness-protected runtime. The emergency
# data-ready dark-standby manifest overrides it to false and does not start the
# app or sync worker at all.
BACKGROUND_JOBS_ENABLED=true
