# WebApp-IR dark-standby operational manifest.
# Copy this file to a root-only path outside the repository. It contains paths
# to secrets, never secret values. Dark standby must not mutate public routing
# or start an application writer.

DARK_STANDBY_MODE=1

SOURCE_RELEASE_SHA=0000000000000000000000000000000000000000
SOURCE_PROJECT_DIR=/root/trading-bot/production-main
SOURCE_RUNTIME_ENV=/root/secure-envs/trading-bot/.env.iran.production

WEBAPP_FI_HOST=65.109.220.59
WEBAPP_FI_SSH_USER=root
WEBAPP_FI_SSH_PORT=37067
WEBAPP_FI_SSH_KEY=/root/.ssh/id_ed25519_iran
WEBAPP_FI_PROJECT_DIR=/srv/trading-bot/current

WA_IR_HOST=185.206.95.250
WA_IR_SSH_USER=ubuntu
WA_IR_SSH_PORT=22
WA_IR_SSH_KEY=/root/.ssh/id_ed25519_iran
WA_IR_PROJECT_DIR=/srv/trading-bot/current
WA_IR_DEPLOY_BASE_DIR=/srv/trading-bot

SERVER_TIMEZONE=UTC
USER_DISPLAY_TIMEZONE=Asia/Tehran

# HMAC values stay only in this root-only credential file. WA-IR receives
# short-lived presigned HTTPS URLs, never the HMAC credential.
OBJECT_STORAGE_PROVIDER=arvan
OBJECT_STORAGE_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
OBJECT_STORAGE_REGION=ir-thr-at1
OBJECT_STORAGE_BUCKET=production-sync-coin
OBJECT_STORAGE_PREFIX=dark-standby
OBJECT_STORAGE_CREDENTIAL_FILE=/root/trading-bot/trading_bot/tmp/secrets/arvan-s3.env
OBJECT_URL_TTL_SECONDS=900

# Client-side encryption is mandatory because Arvan currently rejects object
# writes when its advertised bucket SSE or Public Access Block is enabled.
PAYLOAD_ENCRYPTION=age-x25519
AGE_IDENTITY_FILE=/root/secure-envs/trading-bot/webapp-ir-dark-standby-age-identity.txt
AGE_RECIPIENT_FILE=/root/secure-envs/trading-bot/webapp-ir-dark-standby-age-recipient.txt

# Fail-closed dark state.
BACKGROUND_JOBS_ENABLED=false
START_APP_SERVICE=false
START_SYNC_WORKER=false
RESTORE_REDIS=false
ALLOW_PUBLIC_INGRESS=false
ALLOW_CDN_MUTATION=false
ALLOW_DNS_MUTATION=false
ALLOW_WRITER_PROMOTION=false
WRITER_WITNESS_REQUIRED=false
WRITER_WITNESS_AUTO_RENEW_ENABLED=false

LOCAL_ARTIFACT_DIR=/srv/trading-bot/production-data/dark-standby
REMOTE_BACKUP_DIR=/srv/trading-bot/backups/dark-standby
