# Copy to .env.staging or let scripts/deploy_staging.sh create one.
# Keep this file free of real secrets.

ENVIRONMENT=staging
SERVER_MODE=iran
FRONTEND_URL=http://staging.362514.ir
PUBLIC_WEBAPP_URL=https://staging.gold-trade.ir
BOT_USERNAME=staging_bot_placeholder

DATABASE_URL=postgresql+asyncpg://trading_bot_staging:change-me@db:5432/trading_bot_staging
SYNC_DATABASE_URL=postgresql://trading_bot_staging:change-me@db:5432/trading_bot_staging
POSTGRES_DB=trading_bot_staging
POSTGRES_USER=trading_bot_staging
POSTGRES_PASSWORD=change-me

REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

JWT_SECRET_KEY=change-me
SYNC_API_KEY=change-me
DEV_API_KEY=change-me
OBSERVABILITY_API_KEY=change-me
OBSERVABILITY_TELEGRAM_USER_HASH_SALT=change-me
STAGING_BASIC_AUTH_USER=staging
STAGING_BASIC_AUTH_PASSWORD=change-me
STAGING_ENABLE_DEV_LOGIN=true
STAGING_LOG_OTP_CODES=false

# Staging must not sync with production.
PEER_SERVER_URL=https://staging.362514.ir/foreign-sync
FOREIGN_SERVER_URL=https://staging.362514.ir/foreign-sync
IRAN_SERVER_URL=http://app:8000
GERMANY_SERVER_URL=https://staging.362514.ir/foreign-sync
FOREIGN_SERVER_DOMAIN=staging.362514.ir
IRAN_SERVER_DOMAIN=
FOREIGN_SERVER_ALIASES=staging.362514.ir
IRAN_SERVER_ALIASES=staging.gold-trade.ir,app
EXTRA_CORS_ORIGINS=http://staging.362514.ir
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,172.16.0.0/12

# Dual-platform registration Stage 1 foundation. Keep entry paths and Sync v2
# disabled until their later roadmap stages are deployed and verified.
TELEGRAM_DIRECT_REGISTRATION_ENABLED=0
TELEGRAM_REGISTRATION_RECONCILIATION_ENABLED=0
TELEGRAM_LOGIN_OTP_ENABLED=0
OTP_SMS_AUTO_FALLBACK_ENABLED=0
OTP_SMS_AUTO_FALLBACK_SECONDS=40
OTP_TTL_SECONDS=120
TELEGRAM_REGISTRATION_POST_EXPIRY_GRACE_SECONDS=86400
TELEGRAM_REGISTRATION_JOB_BATCH_SIZE=10
TELEGRAM_REGISTRATION_JOB_CONCURRENCY=1
OTP_SMS_FALLBACK_JOB_CONCURRENCY=4
INVITATION_SMS_STANDARD_ENABLED=0
INVITATION_SMS_CUSTOMER_TIER1_ENABLED=0
INVITATION_SMS_ACCOUNTANT_ENABLED=1
INVITATION_SMS_CUSTOMER_TIER2_ENABLED=1
INVITATION_CONTRACT_V2_ENABLED=0
REGISTRATION_SYNC_V2_ENABLED=0
REGISTRATION_SYNC_ACCEPT_UNVERSIONED=1
INVITATION_PUBLIC_RATE_LIMIT_PER_MINUTE=30

# Leave empty unless a dedicated staging Telegram bot token exists.
BOT_TOKEN=

# Optional foreign-staging Object Storage deploy bridge.
# Keep real credentials only in ignored .env.staging or the shell environment.
ARVAN_OBJECT_STORAGE_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_OBJECT_STORAGE_BUCKET=
ARVAN_OBJECT_STORAGE_PREFIX=staging/deploy-bridge
ARVAN_OBJECT_STORAGE_ACCESS_KEY=
ARVAN_OBJECT_STORAGE_SECRET_KEY=

# Optional multi-artifact Object Storage release bridge.
# Images and encrypted runtime env are opt-in to avoid accidental large uploads
# or plaintext secret transfer.
STAGING_OBJECT_RELEASE_INCLUDE_IMAGES=0
STAGING_OBJECT_RELEASE_INCLUDE_PIP=1
STAGING_OBJECT_RELEASE_INCLUDE_ENV=0
STAGING_OBJECT_RELEASE_ENV_KEY=
STAGING_OBJECT_RELEASE_APPLY_EXECUTE=0
STAGING_OBJECT_RELEASE_DEPLOY_AFTER_APPLY=0
STAGING_OBJECT_RELEASE_CHANNEL=iran-staging
