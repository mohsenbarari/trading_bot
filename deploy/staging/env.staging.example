# Copy to .env.staging or let scripts/deploy_staging.sh create one.
# Keep this file free of real secrets.

ENVIRONMENT=staging
SERVER_MODE=foreign
FRONTEND_URL=http://staging.362514.ir
BOT_USERNAME=staging_bot_placeholder

DATABASE_URL=postgresql+asyncpg://trading_bot_staging:change-me@db:5432/trading_bot_staging
SYNC_DATABASE_URL=postgresql://trading_bot_staging:change-me@db:5432/trading_bot_staging
POSTGRES_DB=trading_bot_staging
POSTGRES_USER=trading_bot_staging
POSTGRES_PASSWORD=change-me

REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

JWT_SECRET_KEY=change-me
SYNC_API_KEY=change-me
DEV_API_KEY=change-me
OBSERVABILITY_API_KEY=change-me
OBSERVABILITY_TELEGRAM_USER_HASH_SALT=change-me
STAGING_BASIC_AUTH_USER=staging
STAGING_BASIC_AUTH_PASSWORD=change-me
STAGING_ENABLE_DEV_LOGIN=true

# Staging must not sync with production.
PEER_SERVER_URL=
FOREIGN_SERVER_URL=
IRAN_SERVER_URL=http://app:8000
GERMANY_SERVER_URL=
FOREIGN_SERVER_DOMAIN=staging.362514.ir
IRAN_SERVER_DOMAIN=
EXTRA_CORS_ORIGINS=http://staging.362514.ir

# Leave empty unless a dedicated staging Telegram bot token exists.
BOT_TOKEN=
