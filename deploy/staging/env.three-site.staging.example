# Each site receives only the directed keys it sends or verifies. Replace all
# secrets independently; never reuse a secret for the reverse direction.
BOT_FI_DR_PAIRWISE_KEYS_JSON=[{"key_id":"bot-to-fi","source_site":"bot_fi","destination_site":"webapp_fi","secret":"CHANGE_ME_bot_to_fi_32_bytes_minimum"},{"key_id":"fi-to-bot","source_site":"webapp_fi","destination_site":"bot_fi","secret":"CHANGE_ME_fi_to_bot_32_bytes_minimum"}]
WEBAPP_FI_DR_PAIRWISE_KEYS_JSON=[{"key_id":"bot-to-fi","source_site":"bot_fi","destination_site":"webapp_fi","secret":"CHANGE_ME_bot_to_fi_32_bytes_minimum"},{"key_id":"fi-to-bot","source_site":"webapp_fi","destination_site":"bot_fi","secret":"CHANGE_ME_fi_to_bot_32_bytes_minimum"},{"key_id":"fi-to-ir","source_site":"webapp_fi","destination_site":"webapp_ir","secret":"CHANGE_ME_fi_to_ir_32_bytes_minimum"},{"key_id":"ir-to-fi","source_site":"webapp_ir","destination_site":"webapp_fi","secret":"CHANGE_ME_ir_to_fi_32_bytes_minimum"}]
WEBAPP_IR_DR_PAIRWISE_KEYS_JSON=[{"key_id":"fi-to-ir","source_site":"webapp_fi","destination_site":"webapp_ir","secret":"CHANGE_ME_fi_to_ir_32_bytes_minimum"},{"key_id":"ir-to-fi","source_site":"webapp_ir","destination_site":"webapp_fi","secret":"CHANGE_ME_ir_to_fi_32_bytes_minimum"}]
BOT_FI_DR_PEERS_JSON=[{"site":"webapp_fi","base_url":"https://webapp-fi-dr.staging.internal:8443"}]
WEBAPP_FI_DR_PEERS_JSON=[{"site":"bot_fi","base_url":"https://bot-fi-dr.staging.internal:8443"},{"site":"webapp_ir","base_url":"https://webapp-ir-dr.staging.internal:8443"}]
WEBAPP_IR_DR_PEERS_JSON=[{"site":"webapp_fi","base_url":"https://webapp-fi-dr.staging.internal:8443"}]

# Bind only the exact host address recorded in the signed staging inventory.
# Host firewalls must allow 8443 solely from the two declared DR peers and 8444
# solely from WebApp-FI/WebApp-IR; no Internet-wide ingress is permitted.
# Loopback is a non-routable template default. The signed role-bundle verifier
# rejects it unless the signed inventory itself (which staging forbids) names
# loopback, so a real campaign must replace every value below.
BOT_FI_DR_BIND_ADDRESS=127.0.0.1
WEBAPP_FI_DR_BIND_ADDRESS=127.0.0.1
WEBAPP_IR_DR_BIND_ADDRESS=127.0.0.1
WITNESS_DR_BIND_ADDRESS=127.0.0.1

# Cross-host names are pinned directly to the signed host inventory. These
# values are injected only into the clients that need each peer.
BOT_FI_PEER_WEBAPP_FI_IP=127.0.0.1
WEBAPP_FI_PEER_BOT_FI_IP=127.0.0.1
WEBAPP_FI_PEER_WEBAPP_IR_IP=127.0.0.1
WEBAPP_FI_WITNESS_IP=127.0.0.1
WEBAPP_IR_PEER_WEBAPP_FI_IP=127.0.0.1
WEBAPP_IR_WITNESS_IP=127.0.0.1

DR_BLOB_OBJECT_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
DR_BLOB_OBJECT_REGION=ir-thr-at1
DR_BLOB_OBJECT_BUCKET=CHANGE_ME_staging_bucket
DR_BLOB_OBJECT_PREFIX=staging/CHANGE_ME_campaign_id/blobs/sha256
DR_BLOB_REQUIRE_VERSIONING=true
STAGING_DR_BLOB_CREDENTIALS_FILE=/run/secrets/staging-dr-blob-s3.json
STAGING_DR_BLOB_ENCRYPTION_KEYRING_FILE=/run/secrets/staging-dr-blob-keyring.json

STAGING_DR_CA_CERT=/run/secrets/staging-dr-ca.crt
STAGING_BOT_FI_TLS_CERT=/run/secrets/bot-fi-dr.crt
STAGING_BOT_FI_TLS_KEY=/run/secrets/bot-fi-dr.key
STAGING_WEBAPP_FI_TLS_CERT=/run/secrets/webapp-fi-dr.crt
STAGING_WEBAPP_FI_TLS_KEY=/run/secrets/webapp-fi-dr.key
STAGING_WEBAPP_IR_TLS_CERT=/run/secrets/webapp-ir-dr.crt
STAGING_WEBAPP_IR_TLS_KEY=/run/secrets/webapp-ir-dr.key
STAGING_WITNESS_TLS_CERT=/run/secrets/witness-dr.crt
STAGING_WITNESS_TLS_KEY=/run/secrets/witness-dr.key
STAGING_WITNESS_SIGNING_KEY=/run/secrets/witness-ed25519-private.key

SMSIR_API_KEY=
WEB_PUSH_ENABLED=false
