# Copy to .env.three-site.staging outside Git and replace every placeholder.
# This file is an inventory of required names only; none of these values are usable secrets.
STAGING_RELEASE_SHA=0000000000000000000000000000000000000000
STAGING_FRONTEND_DOCKER_DIST_DIR=mini_app_dist_staging
ENVIRONMENT=staging
FRONTEND_URL=https://staging.gold-trade.ir
PUBLIC_WEBAPP_URL=https://staging.gold-trade.ir
JWT_SECRET_KEY=replace-with-staging-only-random-secret
BOT_TOKEN=replace-with-staging-only-telegram-token
BOT_USERNAME=replace_with_staging_bot_username
CHANNEL_ID=-1000000000000
CHANNEL_INVITE_LINK=https://example.invalid/staging-channel

BOT_FI_POSTGRES_USER=staging_bot_owner
BOT_FI_POSTGRES_PASSWORD=replace-with-random-owner-password
BOT_FI_POSTGRES_DB=staging_bot
WEBAPP_FI_POSTGRES_USER=staging_webapp_fi_owner
WEBAPP_FI_POSTGRES_PASSWORD=replace-with-random-owner-password
WEBAPP_FI_POSTGRES_DB=staging_webapp_fi
WEBAPP_FI_APP_DB_PASSWORD=replace-with-random-app-password
WEBAPP_FI_PROJECTION_DB_PASSWORD=replace-with-random-projection-password
WEBAPP_FI_CONTROL_DB_PASSWORD=replace-with-random-control-password
WEBAPP_IR_POSTGRES_USER=staging_webapp_ir_owner
WEBAPP_IR_POSTGRES_PASSWORD=replace-with-random-owner-password
WEBAPP_IR_POSTGRES_DB=staging_webapp_ir
WEBAPP_IR_APP_DB_PASSWORD=replace-with-random-app-password
WEBAPP_IR_PROJECTION_DB_PASSWORD=replace-with-random-projection-password
WEBAPP_IR_CONTROL_DB_PASSWORD=replace-with-random-control-password
WITNESS_POSTGRES_USER=staging_witness_owner
WITNESS_POSTGRES_PASSWORD=replace-with-random-witness-password
WITNESS_POSTGRES_DB=staging_witness

# Sparse topology: Bot-FI <-> WebApp-FI <-> WebApp-IR. No Bot-FI/WebApp-IR edge.
BOT_FI_DR_PEERS_JSON=[{"site":"webapp_fi","base_url":"https://webapp_fi_dr_tls"}]
WEBAPP_FI_DR_PEERS_JSON=[{"site":"bot_fi","base_url":"https://bot_fi_dr_tls"},{"site":"webapp_ir","base_url":"https://webapp_ir_dr_tls"}]
WEBAPP_IR_DR_PEERS_JSON=[{"site":"webapp_fi","base_url":"https://webapp_fi_dr_tls"}]
BOT_FI_DR_PAIRWISE_KEYS_JSON=[{"key_id":"bot-fi-to-webapp-fi-v1","source_site":"bot_fi","destination_site":"webapp_fi","secret":"replace-with-32-plus-random-bytes-a"},{"key_id":"webapp-fi-to-bot-fi-v1","source_site":"webapp_fi","destination_site":"bot_fi","secret":"replace-with-32-plus-random-bytes-b"}]
WEBAPP_FI_DR_PAIRWISE_KEYS_JSON=[{"key_id":"bot-fi-to-webapp-fi-v1","source_site":"bot_fi","destination_site":"webapp_fi","secret":"replace-with-32-plus-random-bytes-a"},{"key_id":"webapp-fi-to-bot-fi-v1","source_site":"webapp_fi","destination_site":"bot_fi","secret":"replace-with-32-plus-random-bytes-b"},{"key_id":"webapp-fi-to-webapp-ir-v1","source_site":"webapp_fi","destination_site":"webapp_ir","secret":"replace-with-32-plus-random-bytes-c"},{"key_id":"webapp-ir-to-webapp-fi-v1","source_site":"webapp_ir","destination_site":"webapp_fi","secret":"replace-with-32-plus-random-bytes-d"}]
WEBAPP_IR_DR_PAIRWISE_KEYS_JSON=[{"key_id":"webapp-fi-to-webapp-ir-v1","source_site":"webapp_fi","destination_site":"webapp_ir","secret":"replace-with-32-plus-random-bytes-c"},{"key_id":"webapp-ir-to-webapp-fi-v1","source_site":"webapp_ir","destination_site":"webapp_fi","secret":"replace-with-32-plus-random-bytes-d"}]

STAGING_WITNESS_URL=https://witness_dr_tls
WEBAPP_FI_WITNESS_KEY_ID=staging-webapp-fi-v1
WEBAPP_FI_WITNESS_SECRET=replace-with-32-plus-random-witness-secret-fi
WEBAPP_IR_WITNESS_KEY_ID=staging-webapp-ir-v1
WEBAPP_IR_WITNESS_SECRET=replace-with-32-plus-random-witness-secret-ir
WRITER_WITNESS_PUBLIC_KEY=replace-with-base64-ed25519-public-key
WRITER_WITNESS_AUTO_RENEW_ENABLED=true

DR_BLOB_OBJECT_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
DR_BLOB_OBJECT_REGION=ir-thr-at1
DR_BLOB_OBJECT_BUCKET=replace-with-dedicated-staging-bucket
DR_BLOB_OBJECT_PREFIX=staging/replace-with-campaign-id/blobs/sha256
DR_BLOB_REQUIRE_VERSIONING=true
DR_AUDIT_ANCHOR_OBJECT_PREFIX=staging/replace-with-campaign-id/audit-anchors
STAGING_DR_BLOB_CREDENTIALS_FILE=/replace/with/staging-only-dr-blob-credentials.json

STAGING_DR_CA_CERT=/replace/with/staging-dr-ca.crt
STAGING_BOT_FI_TLS_CERT=/replace/with/bot-fi.crt
STAGING_BOT_FI_TLS_KEY=/replace/with/bot-fi.key
STAGING_WEBAPP_FI_TLS_CERT=/replace/with/webapp-fi.crt
STAGING_WEBAPP_FI_TLS_KEY=/replace/with/webapp-fi.key
STAGING_WEBAPP_IR_TLS_CERT=/replace/with/webapp-ir.crt
STAGING_WEBAPP_IR_TLS_KEY=/replace/with/webapp-ir.key
STAGING_WITNESS_TLS_CERT=/replace/with/witness.crt
STAGING_WITNESS_TLS_KEY=/replace/with/witness.key
STAGING_WITNESS_SIGNING_KEY=/replace/with/witness-ed25519-private-key

ORIGIN_READINESS_API_KEY=replace-with-staging-only-readiness-key
ORIGIN_EXPECTED_MIGRATION_REVISION=d3e8f9a0b1c2
ORIGIN_READINESS_REQUIRE_RECOVERY_MANIFEST=true
DR_ISOLATED_CRITICAL_WRITE_POLICY=freeze
BACKGROUND_JOBS_ENABLED=true
WEB_PUSH_ENABLED=false
SMSIR_API_KEY=
