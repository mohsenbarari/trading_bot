  "comparison_modes": [
    {
      "id": "historical-regression",
      "label": "Mode A - Historical Regression Baseline",
      "compare": [
        "pre-refactor-legacy",
        "current-legacy"
      ],
      "purpose": "Detect whether the current production Messenger regressed against the historical pre-refactor baseline."
    },
    {
      "id": "live-parity",
      "label": "Mode B - Live Parity Comparison",
      "compare": [
        "current-legacy",
        "current-refactor"
      ],
      "purpose": "Detect functional and UX drift while both versions run on the same current backend/runtime."
    },
    {
      "id": "release-gate",
      "label": "Mode C - Release Gate Comparison",
      "compare": [
        "rollout-candidate-refactor",
        "current-production-legacy"
      ],
      "purpose": "Decide whether the refactor can become the default and whether legacy retirement can begin."
    }
  ],
